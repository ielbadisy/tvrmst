% Generated by hand for tvrmst
\name{as_survmat}
\alias{as_survmat}
\title{Coerce Inputs to a survmat Object}
\description{
Coerce survival predictions into a canonical survmat object with components
\code{t} and \code{S}.
}
\usage{
as_survmat(x, t = NULL, orient = c("auto", "time_rows", "time_cols"), strict = TRUE)
}
\arguments{
  \item{x}{A survival prediction object: \code{survmat}, numeric matrix,
  \code{data.frame}, or list-like object containing time and survival entries.}
  \item{t}{Optional numeric time grid. If omitted, time is extracted from
  reliable sources in the object when available.}
  \item{orient}{Orientation of the matrix input.}
  \item{strict}{Logical. If TRUE, enforce strict checks on time grids.}
}
\details{
Time can be supplied explicitly via \code{t}, or extracted from:
\itemize{
  \item data.frame column names like \code{t=0}, \code{t=0.25}, ...
  \item attributes \code{time} or \code{times}
  \item list elements \code{time}/\code{times} with \code{surv}/\code{survival}/\code{S}
  \item numeric dimnames on matrices
}
If time cannot be determined reliably, an error is raised.
}
\value{
A \code{survmat} object (list with components \code{t} and \code{S}).
}
\examples{
 t <- seq(0, 3, by = 1)
 S <- cbind(A = exp(-0.2 * t), B = exp(-0.3 * t))
 sm <- as_survmat(S, t = t)

 df <- data.frame(`t=0` = c(1, 1), `t=1` = c(0.9, 0.85), check.names = FALSE)
 sm2 <- as_survmat(df)

 M <- t(S)
 attr(M, "times") <- t
 sm3 <- as_survmat(M)

 sm4 <- as_survmat(list(time = t, surv = S))
}
